{
  "name": "@pvinis/cloak-secrets",
  "displayName": "Cloak Secrets",
  "description": "Cloak hides/shows your secrets in environment files, to avoid accidentally sharing them with everyone who sees your screen.",
  "publisher": "pvinis",
  "version": "0.0.1",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "icon": "resources/cloak.png",
  "galleryBanner": {
    "color": "#D4B8F0",
    "theme": "dark"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Theme",
    "Colors",
    "Fun"
  ],
  "activationEvents": [
    "workspaceContains:**/.env*"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cloak-secrets.hideSecrets",
        "title": "Cloak Secrets: Hide Secrets"
      },
      {
        "command": "cloak-secrets.hideSecrets",
        "title": "Cloak Secrets: Show Secrets"
      },
      {
        "command": "cloak-secrets.toggleSecrets",
        "title": "Cloak Secrets: Toggle Secrets"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.24.0",
    "typescript": "^5.8.3"
  }
}
